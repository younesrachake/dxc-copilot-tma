# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
APP_PORT=80
APP_URL=https://copilot.dxc.com

# ─── Database ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dxc_copilot_prod
POSTGRES_USER=dxc_admin
POSTGRES_PASSWORD=change_me_in_production

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_TTL=3600

# ─── Auth / JWT ────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
INITIAL_ADMIN_PASSWORD=change_me_min_12_characters

# ─── Backend (docker-compose interpolation) ───────────────────
# Async URL used by the FastAPI backend (compose builds REDIS_URL itself)
DATABASE_URL=postgresql+asyncpg://dxc_admin:change_me_in_production@postgres:5432/dxc_copilot_prod
APP_ENV=production
LOG_JSON=1
SENTRY_DSN=

# ─── AI / LLM ──────────────────────────────────────────────────
GROQ_API_KEY=gsk-...
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=4096

# ─── Backups ───────────────────────────────────────────────────
BACKUP_KEEP=14
BACKUP_INTERVAL_SECONDS=86400

# ─── Observability (docker compose --profile observability) ───
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production

# ─── Integrations ──────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your_jira_api_token
JIRA_USER_EMAIL=admin@dxc.com

TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Storage ───────────────────────────────────────────────────
UPLOAD_MAX_MB=50
LOG_LEVEL=info
LOG_RETENTION_DAYS=90

# ─── Docker Registry ───────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_NAME=dxc/dxc-copilot
IMAGE_TAG=latest
