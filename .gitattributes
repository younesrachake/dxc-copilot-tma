# Normalize line endings; files that run inside Linux containers MUST stay LF
* text=auto

# Shell scripts break with CRLF (bad interpreter in containers)
*.sh text eol=lf
Dockerfile text eol=lf
*.Dockerfile text eol=lf

# Config consumed by Linux services
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.sql text eol=lf
*.py text eol=lf
*.mako text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
