# ═══════════════════════════════════════════════════════════════════
# DXC Copilot TMA — Backend Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# SQLite (dev)
DATABASE_URL=sqlite+aiosqlite:///./dxc_copilot.db
# PostgreSQL (prod)
# DATABASE_URL=postgresql+asyncpg://dxc_admin:dxcsecret2024@localhost:5432/dxc_copilot_prod

# ── JWT Authentication ────────────────────────────────────────────
JWT_SECRET=dxc_copilot_dev_secret_key_change_in_prod_32chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ── OpenAI / LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-placeholder-set-your-real-key

# ── Redis (optional, for caching / rate-limiting) ─────────────────
REDIS_URL=redis://:dxcredis2024@localhost:6379/0

# ── CORS Allowed Origins ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200,http://localhost:80,http://localhost

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute

# ── File Upload ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=15
