# ═══════════════════════════════════════════════════════════════════
# DXC Copilot TMA — Backend Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# SQLite (dev)
DATABASE_URL=sqlite+aiosqlite:///./dxc_copilot.db
# PostgreSQL (prod)
# DATABASE_URL=postgresql+asyncpg://dxc_admin:dxcsecret2024@localhost:5432/dxc_copilot_prod

# ── JWT Authentication ────────────────────────────────────────────
JWT_SECRET=dxc_copilot_dev_secret_key_change_in_prod_32chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ── OpenAI / LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-placeholder-set-your-real-key

# ── Redis (optional, for caching / rate-limiting) ─────────────────
REDIS_URL=redis://:dxcredis2024@localhost:6379/0

# ── CORS Allowed Origins ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200,http://localhost:80,http://localhost

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute

# ── File Upload ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=15

# ── SSO / OIDC (Microsoft Entra ID / Azure AD) ────────────────────
# Register an app at https://portal.azure.com → Microsoft Entra ID →
# App registrations → New registration.
#   • Redirect URI (type "Web"): must exactly match SSO_REDIRECT_URI below
#   • Client ID   → SSO_CLIENT_ID          (Application (client) ID)
#   • Tenant ID   → SSO_TENANT_ID          (Directory (tenant) ID)
#   • Client secret → SSO_CLIENT_SECRET    (Certificates & secrets → New client secret)
# SSO stays disabled until all three of ID / SECRET / TENANT are set.
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_TENANT_ID=
SSO_REDIRECT_URI=http://localhost:8000/api/auth/sso/callback

# Where users land in the SPA after a successful SSO login
FRONTEND_URL=http://localhost:4200
